PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/departure_job_portal
MONGODB_DB_NAME=departure_job_portal
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGINS=http://localhost:3001,https://your-frontend.vercel.app
# CLIENT_ORIGIN and FRONTEND_URL remain supported for a single origin.

# Use CLOUDINARY_URL, or provide all three individual values below.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
